# macOS 
.DS_Store
__MACOSX/

# Object files & Libraries
*.o
*.so
*.dylib
*.a
*.cmd

# Temporary / System Extraction Directories
tmp/
initramfs/
vm/_*/
vm/mnt/
vm/pgsql/
vm/snapshots/
vm/rootfs_patch/
vm/check_initramfs/
extension/archived_files/

# The massive Ext4 / Linux Source Trees
linux-src/
vm/pg18.tar.bz2

# Extracted OS binaries / debug dumps
vm/*.img
vm/*.img.bak
vm/init
vm/System.map
vm/dash
vm/postgres_wrapper
vm/rv64_test
vm/initdb.asm
vm/*.txt

# Ignore specific VM environment test binaries
vm/initdb.elf

# Guest test binaries
guest/fp_probe
guest/*.dis
guest/rv64_test_new

# --- AGGRESSIVE DEBUG EXCLUSIONS ---
# Execution logs
*.log
*.txt

# Python debug scripts in extension
extension/*.py
parse_map.py

# Bash wrapper debugs in extension
extension/*.sh
vm_run.sh

# Patch fragments
*.patch
*.orig
*.rej
*.bak

